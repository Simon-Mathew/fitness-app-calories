# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB — local:
MONGO_URI=mongodb://127.0.0.1:27017/fitness-app

# MongoDB — Atlas (cloud), uncomment and replace when deploying:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fitness-app?retryWrites=true&w=majority
